# Paths
DATA_PATH=data/urls.csv
MODEL_PATH=models/phishing_model.joblib
METRICS_PATH=data/metrics.json
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=phishing-url-classifier

# API
